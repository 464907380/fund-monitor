[Unit]
Description=基金监控 — 全球股市简报（8:30）
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 /opt/fund-monitor/src/global_briefing.py
WorkingDirectory=/opt/fund-monitor
User=nobody
Group=nogroup
# 读取环境变量
EnvironmentFile=/opt/fund-monitor/.env
StandardOutput=journal
StandardError=journal
